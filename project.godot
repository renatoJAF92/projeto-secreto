; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Destiny — Tales of Natalia"
run/main_scene="res://scenes/main_menu/main_menu.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://assets/audio/default_bus_layout.tres"

[autoload]

Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
SaveManager="*res://autoloads/save_manager.gd"
SceneTransition="*res://scenes/scene_transition/scene_transition.tscn"
ControlsManager="*res://autoloads/controls_manager.gd"
AudioManager="*res://autoloads/audio_manager.gd"
GameOverManager="*res://autoloads/game_over_manager.gd"
TouchControls="*res://autoloads/touch_controls.gd"

[dialogic]

choices/autofocus_first=false
choices/delay=0.0
directories/dch_directory={
"Luis": "res://dialogic/characters/Luis.dch",
"Natalia": "res://dialogic/characters/Natalia.dch",
"ProfessorPerpetuo": "res://dialogic/characters/ProfessorPerpetuo.dch",
"Renato": "res://dialogic/characters/Renato.dch"
}
directories/dtl_directory={
"boss_abertura": "res://dialogic/timelines/boss_abertura.dtl",
"boss_abertura_bloqueado": "res://dialogic/timelines/boss_abertura_bloqueado.dtl",
"boss_abertura_tfg": "res://dialogic/timelines/boss_abertura_tfg.dtl",
"boss_derrota": "res://dialogic/timelines/boss_derrota.dtl",
"boss_intro": "res://dialogic/timelines/boss_intro.dtl",
"boss_renato_entrada": "res://dialogic/timelines/boss_renato_entrada.dtl",
"boss_vitoria": "res://dialogic/timelines/boss_vitoria.dtl",
"boss_vitoria_tfg": "res://dialogic/timelines/boss_vitoria_tfg.dtl",
"dia_seguinte": "res://dialogic/timelines/dia_seguinte.dtl",
"mundo1_abertura": "res://dialogic/timelines/mundo1_abertura.dtl",
"mundo2_abertura": "res://dialogic/timelines/mundo2_abertura.dtl",
"renato_restaurante": "res://dialogic/timelines/renato_restaurante.dtl",
"restaurante_saida": "res://dialogic/timelines/restaurante_saida.dtl",
"test_dialogue": "res://dialogic/timelines/test_dialogue.dtl"
}
layout/default_style="res://dialogic/pixel_art_style.tres"
layout/style_directory={
"": "res://dialogic/pixel_art_style.tres",
"Pixel Art Style": "res://dialogic/pixel_art_style.tres"
}
layout/style_list=PackedStringArray("res://dialogic/pixel_art_style.tres")

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/initial_position=Vector2i(1280, 720)
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"
window/handheld/orientation=6

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")


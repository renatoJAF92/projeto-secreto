; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Destiny — Tales of Natalia"
run/main_scene="res://scenes/main_menu/main_menu.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
SaveManager="*res://autoloads/save_manager.gd"
SceneTransition="*res://scenes/scene_transition/scene_transition.tscn"
ControlsManager="*res://autoloads/controls_manager.gd"
AudioManager="*res://autoloads/audio_manager.gd"

[dialogic]

directories/dch_directory={
"Natalia": "res://dialogic/characters/Natalia.dch",
"Renato": "res://dialogic/characters/Renato.dch"
}
directories/dtl_directory={
"test_dialogue": "res://dialogic/timelines/test_dialogue.dtl"
}
layout/default_style="res://dialogic/pixel_art_style.tres"
layout/style_directory={
"": "res://dialogic/pixel_art_style.tres",
"Pixel Art Style": "res://dialogic/pixel_art_style.tres"
}
layout/style_list=PackedStringArray("res://dialogic/pixel_art_style.tres")

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/initial_position=Vector2i(1280, 720)
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

